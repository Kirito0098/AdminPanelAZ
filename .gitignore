# =============================================================================
# AdminPanelAZ — не коммитить runtime, секреты и артефакты сборки
# Основные пути: backend/data/ (DATABASE_URL), backend/.env, .runtime/
# =============================================================================

# --- Secrets & environment (шаблоны *.env.example остаются в git) ---
.env
.env.*
*.env
!*.env.example
!**/.env.example
ddns.env
.reinstall-backup/

# --- SQLite & runtime databases (WAL mode включён в database.py) ---
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
*.sqlite-wal
*.sqlite-shm

# --- Runtime data: backend/data/ (primary — sqlite:///./data/ относительно backend/) ---
backend/data/

# --- Runtime data: repo root data/ (только .gitkeep для onboarding-каталогов) ---
/data/**
!/data/**/.gitkeep

# GeoIP MMDB (пользователь загружает сам; см. docs/GeoIP.md)
*.mmdb

# --- CIDR pipeline (legacy / дублирующие пути) ---
backend/app/data/

# --- mTLS / crypto material (generate-mtls-certs.sh → /etc/adminpanelaz по умолчанию) ---
*.pem
*.key
*.crt
*.p12
*.pfx

# --- Backup archives & temp payloads (backup-cli, restore, pipeline) ---
*.tar.gz
*.tar
.tmp_*

# --- Python ---
backend/.venv/
**/__pycache__/
*.pyc
.pytest_cache/
**/.pytest_cache/
.coverage
coverage.xml
htmlcov/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# --- Node / frontend builds ---
frontend/node_modules/
frontend/dist/
frontend/.vite/
backend/app/static/tg_mini/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Runtime logs, PIDs, local state (start.sh → .runtime/ или ADMINPANELAZ_STATE_DIR) ---
.start.sh.pids
.runtime/
*.log

# --- IDE / OS ---
.idea/
.vscode/
.cursor/
*.swp
*~
.DS_Store
Thumbs.db
