# development | production (production проверяет секреты при старте)
APP_ENV=development
SECRET_KEY=change-me-in-production-use-long-random-string
DATABASE_URL=sqlite:///./data/adminpanel.db
CIDR_DATABASE_URL=sqlite:///./data/cidr/cidr.db
ANTIZAPRET_PATH=/root/antizapret
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:8000
# Prod daemon sets automatically:
# SERVE_FRONTEND=true
# FRONTEND_DIST_PATH=/opt/AdminPanelAZ/frontend/dist
# Bootstrap only (install wizard): written to SQLite on first setup, then cleared from .env after password change.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_MUST_CHANGE_PASSWORD=true
ALLOW_INTERNAL_NODES=false
# false = панель без локального AntiZapret (только удалённые node agent); локальный узел не создаётся
LOCAL_ANTIZAPRET_ENABLED=true
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
# UVICORN_WORKERS=1
# Nginx reverse proxy (scripts/nginx-setup.sh или install.sh):
# BEHIND_NGINX=true
# DOMAIN=panel.example.com
# ENFORCE_HTTPS=true
# TRUSTED_PROXY_IPS=127.0.0.1,::1
# FORWARDED_ALLOW_IPS=127.0.0.1,::1
# Production: задайте только ваш домен
# CORS_ORIGINS=https://panel.example.com
# AUTH_RATE_LIMIT_ENABLED=true
# AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
# AUTH_RATE_LIMIT_WINDOW_SECONDS=300
# AUTH_RATE_LIMIT_BACKEND=memory
# При UVICORN_WORKERS > 1: AUTH_RATE_LIMIT_BACKEND=redis и REDIS_URL (см. SECURITY.md)
# REDIS_URL=redis://127.0.0.1:6379/0
# API_RATE_LIMIT_ENABLED=true
# API_RATE_LIMIT_MAX_REQUESTS=120
# API_RATE_LIMIT_WINDOW_SECONDS=60
# API_RATE_LIMIT_BACKEND=memory
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=7
# REFRESH_TOKEN_COOKIE_SECURE=false
# REFRESH_TOKEN_COOKIE_SAMESITE=lax
# NODE_AGENT_MTLS_ENABLED=false  # DEPRECATED: режим mTLS задаётся per-node (nodes.mtls_enabled в БД);
#                                  # глобальный флаг — только legacy backfill при миграции. Включайте mTLS
#                                  # на странице «Узлы» → «Включить mTLS» для каждого удалённого узла.
# NODE_AGENT_MTLS_CA_CERT=/etc/adminpanelaz/mtls/ca.crt
# NODE_AGENT_MTLS_CLIENT_CERT=/etc/adminpanelaz/mtls/panel.crt
# NODE_AGENT_MTLS_CLIENT_KEY=/etc/adminpanelaz/mtls/panel.key
# NODE_API_KEY_ROTATION_DAYS=0
# NODE_API_KEY_ROTATION_CHECK_HOURS=24
# SECURITY_HEADERS_ENABLED=true
# ENFORCE_PASSWORD_POLICY=true
# MIN_PASSWORD_LENGTH=8
# AUDIT_LOG_ENABLED=true
NODE_AGENT_PORT=9100
# NODE_AGENT_API_KEY=  # задаётся при установке с node agent (см. backend/node_agent.env)
BACKUP_ROOT=/var/backups/adminpanelaz
CIDR_LIST_DIR=data/cidr/list
# CSV staging for fast CIDR DB ingest (runtime; see backend/data/cidr/staging)
# CIDR_DB_STAGING_DIR=data/cidr/staging
# CIDR_DB_CSV_IMPORT_BATCH=10000
# CIDR_DB_CSV_IMPORT_CHUNK_ROWS=50000
# CIDR_DB_KEEP_STAGING_CSV=0
CIDR_DB_REFRESH_ENABLED=true
CIDR_DB_REFRESH_HOUR=2
CIDR_DB_REFRESH_MINUTE=30
# Nightly pipeline (ingest only by default; optional compile + deploy after refresh)
CIDR_DB_COMPILE_AFTER_REFRESH=false
CIDR_DB_DEPLOY_AFTER_COMPILE=false
# active | all_online | node_ids
CIDR_DB_DEPLOY_TARGET=active
# Comma-separated node IDs when CIDR_DB_DEPLOY_TARGET=node_ids
# CIDR_DB_DEPLOY_TARGET_NODE_IDS=1,2
ANTIFILTER_URL=https://antifilter.download/list/allyouneed.lst
TRAFFIC_SYNC_ENABLED=true
TRAFFIC_SYNC_INTERVAL_SECONDS=60
RESOURCE_METRICS_ENABLED=true
RESOURCE_METRICS_INTERVAL_SECONDS=60
RESOURCE_METRICS_RETENTION_DAYS=30
PANEL_RESOURCE_METRICS_ENABLED=true
PANEL_RESOURCE_METRICS_INTERVAL_SECONDS=60
PANEL_RESOURCE_METRICS_RETENTION_DAYS=30
TRAFFIC_DB_STALE_SECONDS=600
OPENVPN_SOCKET_DIR=/run/openvpn-server
OPENVPN_SOCKET_TIMEOUT=2.5
OPENVPN_SOCKET_IDLE_TIMEOUT=0.12
OPENVPN_LOG_TAIL_LINES=200
OPENVPN_EVENT_MAX_RESPONSE_BYTES=524288
