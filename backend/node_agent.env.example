# Node agent environment (создаётся install.sh, не коммитить)
NODE_AGENT_API_KEY=change-me-node-agent-key
# Production: openssl rand -hex 32 (минимум 24 символа)
# NODE_AGENT_ALLOWED_IPS=10.0.0.5/32
ANTIZAPRET_PATH=/root/antizapret
NODE_AGENT_HOST=0.0.0.0
NODE_AGENT_PORT=9100
NODE_AGENT_STATE_DIR=/var/lib/adminpanelaz-node
NODE_AGENT_MODE=prod
# mTLS (опционально, см. scripts/generate-mtls-certs.sh):
# NODE_AGENT_MTLS_ENABLED=false
# NODE_AGENT_MTLS_SERVER_CERT=/etc/adminpanelaz/mtls/agent.crt
# NODE_AGENT_MTLS_SERVER_KEY=/etc/adminpanelaz/mtls/agent.key
# NODE_AGENT_MTLS_CA_CERT=/etc/adminpanelaz/mtls/ca.crt
# NODE_AGENT_ENV_FILE=/opt/AdminPanelAZ/backend/node_agent.env
