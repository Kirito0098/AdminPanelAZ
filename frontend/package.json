{
  "name": "adminpanel-az-frontend",
  "private": true,
  "version": "2.18.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:tg-mini": "vite --mode tg-mini --open /tg-mini.html",
    "build": "vite build",
    "build:tg-mini": "vite build --mode tg-mini && mv ../backend/app/static/tg_mini/tg-mini.html ../backend/app/static/tg_mini/index.html && sed -i 's/ crossorigin//g' ../backend/app/static/tg_mini/index.html && sed -i 's/type=\"module\" //g' ../backend/app/static/tg_mini/index.html",
    "build:all": "npm run build && npm run build:tg-mini",
    "preview": "vite preview",
    "lint": "eslint . --quiet"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-progress": "^1.1.9",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.14",
    "@simplewebauthn/browser": "^13.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.4.2"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
