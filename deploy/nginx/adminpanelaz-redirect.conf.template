# AdminPanelAZ — редирект 443 → uvicorn HTTPS на другом порту (multi-site)
# Плейсхолдеры: __DOMAIN__, __UVICORN_PORT__, __SSL_CERT__, __SSL_KEY__

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name __DOMAIN__;

    ssl_certificate __SSL_CERT__;
    ssl_certificate_key __SSL_KEY__;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    return 301 https://__DOMAIN__:__UVICORN_PORT__$request_uri;
}
